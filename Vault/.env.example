# Vault/.env.example
#
# Template for Vault/.env — the real values file.
# Copy this to Vault/.env and fill in. Never commit .env.
#
# Every key listed here must also appear in Vault/key-inventory.md
# with a description of what it's for and which workflows/projects use it.

# === Anthropic / Claude ===
ANTHROPIC_API_KEY=

# === GitHub ===
GITHUB_TOKEN=

# === fal.ai — AI image generation + VibeVoice voiceovers ===
# Get from https://fal.ai/dashboard/keys
FAL_KEY=

# === OpenAI — used by gbrain for embeddings ===
# Get from https://platform.openai.com/api-keys
# Cost estimate: ~$0.10 for a small vault, ~$4-5 for 5,000+ pages.
OPENAI_API_KEY=

# === Supabase — used by gbrain as the retrieval layer ===
# IMPORTANT: This is NOT a Supabase Personal Access Token (sbp_...).
# It's a Postgres connection string from your Supabase project's
# "Connect" button → "Session pooler" tab. The URL looks like:
#   postgresql://postgres.xxxxx:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
# Port MUST be 6543 (Session pooler), not 5432 (Direct, IPv6-only).
SUPABASE_POOLER_URL=

# === Processing / connectors (future) ===
# Add keys for each connector as you wire them up.
# HEPTABASE_API_KEY=
# GRANOLA_API_KEY=
# GMAIL_OAUTH_REFRESH_TOKEN=
